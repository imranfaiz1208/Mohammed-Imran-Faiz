{% comment %}
  This section displays a grid of up to 6 products.

  - Products are selectable from the Theme Customizer.
  - Each product has a trigger to open a popup with more details.
  - The popup is a single element, populated dynamically with JS.
  - Product data is pre-loaded into a JSON script tag for performance.
{% endcomment %}

<div class="product-grid-section page-width">
  <div class="product-grid">
    {%- for i in (1..6) -%}
      {%- liquid
        assign block_product_setting = "product_" | append: i
        assign product = section.settings[block_product_setting]
      -%}
      <div class="product-grid-item">
        {%- if product != blank -%}
          <div class="product-grid-item__media">
            <img
              src="{{ product.featured_image | image_url: width: 500 }}"
              alt="{{ product.featured_image.alt | escape }}"
              loading="lazy"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
            >
          </div>
          <button
            class="popup-trigger"
            aria-haspopup="dialog"
            aria-label="View details for {{ product.title | escape }}"
            data-product-handle="{{ product.handle }}">
            <span class="visually-hidden">Open product quick view</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--icon-stroke-width)" d="M16.608 9.421V6.906H3.392v8.016c0 .567.224 1.112.624 1.513.4.402.941.627 1.506.627H8.63M8.818 3h2.333c.618 0 1.212.247 1.649.686a2.35 2.35 0 0 1 .683 1.658v1.562H6.486V5.344c0-.622.246-1.218.683-1.658A2.33 2.33 0 0 1 8.82 3"/><path stroke="currentColor" stroke-linecap="round" stroke-width="var(--icon-stroke-width)" d="M14.608 12.563v5m2.5-2.5h-5"/></svg>
          </button>
        {%- else -%}
          <div class="product-grid-item__placeholder">
            {{ 'product-app-block-placeholder' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%}
    This is the popup structure. It's hidden by default.
    JS will populate it and make it visible.
  {%- endcomment -%}
  <div id="product-popup" class="product-popup" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
    <div class="product-popup__overlay"></div>
    <div class="product-popup__content">
      <button class="product-popup__close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="6.25" stroke="currentColor" stroke-width="var(--icon-stroke-width)"/><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="var(--icon-stroke-width)" d="m12.5 7.5-5 5M12.5 12.5l-5-5"/></svg>
      </button>
      <div class="product-popup__body">
        {%- comment %} Product details will be injected here by JavaScript {%- endcomment %}
      </div>
    </div>
  </div>
</div>

{%- comment -%}
  Pre-fetch product data to avoid multiple AJAX requests.
  This is more efficient and improves user experience.
{%- endcomment -%}
<script type="application/json" id="GridProductData">
  {
    {%- assign product_handle_string = "" -%}
    {%- for i in (1..6) -%}
      {%- assign product_setting_key = 'product_' | append: i -%}
      {%- assign product_object = section.settings[product_setting_key] -%}
      {%- if product_object != blank -%}
        {%- unless product_handle_string contains product_object.handle -%}
          {%- assign product_handle_string = product_handle_string | append: product_object.handle | append: ',' -%}
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign unique_handles = product_handle_string | split: ',' -%}
    {%- assign first_item_printed = false -%}
    {%- for handle in unique_handles -%}
      {%- if handle != "" -%}{%- if first_item_printed %},{% endif %}"{{ handle }}": {{ all_products[handle] | json }}{%- assign first_item_printed = true -%}{%- endif -%}
    {%- endfor -%}
  }
</script>

{%- liquid
  assign soft_winter_jacket = section.settings.conditional_product
  if soft_winter_jacket.variants.size > 0
    assign conditional_variant_id = soft_winter_jacket.first_available_variant.id
  endif
-%}
<script
  type="application/json"
  id="GridConditionalProduct"
  data-variant-id="{{ conditional_variant_id }}">
</script>

<script src="{{ 'custom-page.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .product-grid-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .product-grid-item__media img,
  .product-grid-item__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-grid-item:hover .product-grid-item__media img {
    transform: scale(1.05);
  }

  .popup-trigger {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .product-popup {
    display: none; /* Hidden by default */
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-popup[aria-hidden="true"] {
    display: none;
  }

  .product-popup__overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.5);
  }

  .product-popup__content {
    position: relative;
    background-color: rgb(var(--color-background));
    padding: 2rem;
    border-radius: var(--popup-border-radius);
    max-width: 800px;
    width: 90%;
    z-index: 101;
  }

  .product-popup__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  @media screen and (max-width: 749px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Custom Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Product Selection"
    },
    {
      "type": "paragraph",
      "content": "Select up to 6 products to display in the grid."
    },
    { "type": "product", "id": "product_1", "label": "Product 1" },
    { "type": "product", "id": "product_2", "label": "Product 2" },
    { "type": "product", "id": "product_3", "label": "Product 3" },
    { "type": "product", "id": "product_4", "label": "Product 4" },
    { "type": "product", "id": "product_5", "label": "Product 5" },
    { "type": "product", "id": "product_6", "label": "Product 6" },
    {
      "type": "header",
      "content": "Conditional Cart Logic"
    },
    {
      "type": "product",
      "id": "conditional_product",
      "label": "Conditional Product",
      "info": "This product will be added to the cart automatically when a product with 'Black' and 'Medium' variants is added."
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}